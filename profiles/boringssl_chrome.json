{
  "profile_id": "boringssl_chrome",
  "description": "Runtime template for Chrome family using BoringSSL. Cross-version stable knowledge extracted from Chrome 143.0.7499.169 ground truth (Phase P3/P4 verified).",
  "tls_lib": "boringssl",
  "applies_to": {
    "browsers": ["chrome", "edge", "electron"],
    "platforms": ["linux"],
    "archs": ["x86_64"]
  },
  "client_random": {
    "path": "*(*(*(ssl_ptr) + 0x30) + 0x30)",
    "steps": [
      "s3 = ssl_ptr.readPointer()",
      "sub = s3.add(0x30).readPointer()",
      "cr = sub.add(0x30).readByteArray(32)"
    ],
    "length": 32,
    "critical_note": "offset is +0x30 NOT +0x10"
  },
  "tls13_key_len_offsets": {
    "c_e_traffic": "0x81",
    "c_hs_traffic": "0xb2",
    "s_hs_traffic": "0xe3",
    "c_ap_traffic": "0x114",
    "s_ap_traffic": "0x145",
    "exp_master": {
      "path": "*(*(*(ssl_ptr) + 0x30) + 0x1b2)",
      "note": "two-level dereference, different from other labels"
    }
  },
  "tls13_label_map": {
    "c e traffic": "CLIENT_EARLY_TRAFFIC_SECRET",
    "c hs traffic": "CLIENT_HANDSHAKE_TRAFFIC_SECRET",
    "s hs traffic": "SERVER_HANDSHAKE_TRAFFIC_SECRET",
    "c ap traffic": "CLIENT_TRAFFIC_SECRET_0",
    "s ap traffic": "SERVER_TRAFFIC_SECRET_0",
    "exp master": "EXPORTER_SECRET"
  },
  "struct_offsets": {
    "ssl_st_rbio": "0x240",
    "ssl_st_wbio": "0x248",
    "bio_st_num": "0x03c",
    "ssl_st_ext_ms_flag": {
      "offset": "0x812",
      "mask": "0x02"
    },
    "fd_precision_note": "rbio offset valid on ssl_st* but HKDF args[0] is NOT ssl_st*"
  },
  "five_tuple_strategy": {
    "primary": "time_correlation",
    "ebpf_tracepoint": "syscalls/sys_enter_connect + sys_exit_connect",
    "ebpf_filter": "AF_INET, dst_port=443",
    "fd_precise": false,
    "hit_rate_baseline": "100% (718/718 in P4 validation)"
  },
  "hook_templates": {
    "prf": {
      "function_name": "boringssl_tls1_prf",
      "role": "TLS 1.2 Unified PRF",
      "read_on": "onLeave",
      "output_len": 48,
      "params": {
        "ssl_ptr": "args[0] (RDI)",
        "output_buf": "args[1] (RSI)",
        "output_len": "args[2] (RDX, fixed 0x30=48)"
      }
    },
    "key_expansion": {
      "function_name": "boringssl_tls1_key_expansion",
      "role": "TLS 1.2 key block derivation (supplementary)",
      "read_on": "onLeave",
      "note": "master_secret via calibrated memory path",
      "params": {
        "ssl_ptr": "args[0] (RDI)"
      }
    },
    "hkdf": {
      "function_name": "boringssl_tls13_derive_secret",
      "role": "TLS 1.3 Derive-Secret (single hook for all labels)",
      "read_on": "onLeave",
      "params": {
        "ssl_ptr": "args[0] (RDI) — NOT ssl_st*, HKDF internal context",
        "output_buf": "args[1] (RSI)",
        "hkdf_ctx": "args[2] (RDX)",
        "label_ptr": "args[3] (RCX)",
        "label_len": "args[4] (R8)",
        "evp_md": "args[5] (R9)"
      }
    },
    "ssl_log_secret": {
      "function_name": "ssl_log_secret",
      "role": "NSS keylog output (covers PSK/Session Ticket)",
      "read_on": "onEnter",
      "source_note": "BoringSecretHunter v1.2.1"
    }
  }
}
